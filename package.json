{
  "name": "saved-brain",
  "version": "1.0.0",
  "description": "Turn everything you've saved into a searchable, AI-enriched knowledge base",
  "private": true,
  "author": "manazoid4",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/manazoid4/saved-brain.git"
  },
  "keywords": [
    "knowledge-base",
    "ai",
    "bookmark-manager",
    "second-brain",
    "nextjs"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit && next lint",
    "db:setup": "tsx scripts/setup-db.ts",
    "db:seed": "tsx scripts/seed-demo.ts",
    "extension:build": "cd extension && npm run build",
    "extension:clean": "cd extension && npm run clean",
    "extension:zip": "cd extension && npm run zip",
    "extension:test": "cd extension && npm run test",
    "test": "vitest run"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.3",
    "@supabase/supabase-js": "^2.108.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vercel/postgres": "^0.10.0",
    "autoprefixer": "^10.4.19",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.5",
    "jose": "^5.6.3",
    "lucide-react": "^0.400.0",
    "next": "^14.2.5",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^3.4.0",
    "sharp": "^0.33.4",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "vitest": "^1.6.0"
  }
}
